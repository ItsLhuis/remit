{
  "name": "remit",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Open-source, self-hostable business management tool built for freelancers",
  "homepage": "https://github.com/ItsLhuis/remit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ItsLhuis/remit"
  },
  "license": "MIT",
  "author": "ItsLhuis",
  "scripts": {
    "prepare": "husky",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "database:generate": "drizzle-kit generate",
    "database:migrate": "drizzle-kit migrate",
    "database:studio": "drizzle-kit studio",
    "version:patch": "tsx ./scripts/bump-version.ts patch",
    "version:minor": "tsx ./scripts/bump-version.ts minor",
    "version:major": "tsx ./scripts/bump-version.ts major"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-hotkeys": "^0.9.1",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-data-list": "^1.6.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "i18next": "^26.0.8",
    "i18next-icu": "^2.4.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-circle-flags": "^0.0.27",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.6",
    "react-resizable-panels": "^4.9.0",
    "recharts": "3.8.0",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "chalk": "^5.6.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
