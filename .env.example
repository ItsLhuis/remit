# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=remit
POSTGRES_PASSWORD=remit
POSTGRES_DB=remit

# Full connection string used by Drizzle and the app
# Dev:  postgresql://remit:remit@localhost:5432/remit
# Prod: postgresql://remit:<password>@db:5432/remit  (docker-compose builds this automatically)
DATABASE_URL=postgresql://remit:remit@localhost:5432/remit

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Full URL where the app runs - no trailing slash
# Dev:  http://localhost:3000
# Prod: https://yourdomain.com
BETTER_AUTH_URL=http://localhost:3000

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Port exposed by the production container (default: 3000)
PORT=3000

# ─── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ROOT_USER=remit
MINIO_ROOT_PASSWORD=

# Dev:  http://localhost:9000
# Prod: http://minio:9000  (docker-compose sets this automatically)
MINIO_ENDPOINT=http://localhost:9000

MINIO_BUCKET=remit

# Public URL used to build file URLs returned to the browser
# Dev:  http://localhost:9000
# Prod: https://storage.yourdomain.com
MINIO_PUBLIC_URL=http://localhost:9000

# Ports exposed by MinIO (defaults: 9000 API, 9001 console)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
